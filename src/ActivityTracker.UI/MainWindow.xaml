<Window x:Class="ActivityTracker.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:views="clr-namespace:ActivityTracker.UI.Views"
        mc:Ignorable="d"
        Title="ActivityTracker"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        ui:WindowHelper.UseModernWindowStyle="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <ui:TitleBar x:Name="TitleBar"
                     Grid.Row="0"
                     Title="ActivityTracker"
                     Icon="Assets/app.ico"
                     Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
            <ui:TitleBar.ExtendViewIntoTitleBar>
                <ui:ExtendViewIntoTitleBar Trigger="True" />
            </ui:TitleBar.ExtendViewIntoTitleBar>
        </ui:TitleBar>

        <!-- NavigationView sidebar -->
        <ui:NavigationView x:Name="NavView"
                           Grid.Row="1"
                           IsBackButtonVisible="Collapsed"
                           IsSettingsVisible="True"
                           PaneDisplayMode="LeftCompact"
                           OpenPaneLength="220"
                           SelectionChanged="NavView_SelectionChanged"
                           Background="{DynamicResource SystemControlAcrylicWindowBrush}">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Icon="Home"     Content="Dashboard" Tag="Dashboard"/>
                <ui:NavigationViewItem Icon="Calendar" Content="History"   Tag="History"/>
                <ui:NavigationViewItem Icon="AllApps"  Content="App List"  Tag="AppList"/>
            </ui:NavigationView.MenuItems>

            <!-- Content frame -->
            <Frame x:Name="ContentFrame"
                   NavigationUIVisibility="Hidden"
                   Margin="0" />
        </ui:NavigationView>
    </Grid>
</Window>
