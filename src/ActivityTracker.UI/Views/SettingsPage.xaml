<Page x:Class="ActivityTracker.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:vm="clr-namespace:ActivityTracker.UI.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
      Title="Settings"
      Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <!-- Page title -->
            <TextBlock Text="Settings"
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                       Margin="0,0,0,24"/>

            <!-- Monitoring controls -->
            <Border Margin="0,0,0,12" CornerRadius="8"
                     Background="{DynamicResource SystemControlAcrylicElementBrush}"
                     BorderBrush="{DynamicResource SystemControlForegroundTransparentBrush}"
                     BorderThickness="1">
                <StackPanel Margin="20,16">
                    <TextBlock Text="Monitoring"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               Margin="0,0,0,12"/>

                    <!-- Scan interval -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Scan Interval (seconds):"
                                   Width="200" VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <ui:NumberBox Value="{Binding ScanIntervalSeconds, Mode=TwoWay}"
                                      Minimum="1" Maximum="60"
                                      Width="80"/>
                    </StackPanel>

                    <!-- Retention days -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Retention (days):"
                                   Width="200" VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <ui:NumberBox Value="{Binding RetentionDays, Mode=TwoWay}"
                                      Minimum="1" Maximum="365"
                                      Width="80"/>
                    </StackPanel>

                    <!-- Pause / Resume -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Control:"
                                   Width="200" VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <Button Content="{Binding PauseButtonText}"
                                Command="{Binding TogglePauseCommand}"
                                Width="180"
                                Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Startup -->
            <Border Margin="0,0,0,12" CornerRadius="8"
                     Background="{DynamicResource SystemControlAcrylicElementBrush}"
                     BorderBrush="{DynamicResource SystemControlForegroundTransparentBrush}"
                     BorderThickness="1">
                <StackPanel Margin="20,16">
                    <TextBlock Text="Startup"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Launch on system startup:"
                                   Width="200" VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <ToggleSwitch IsOn="{Binding AutoStart, Mode=TwoWay}"
                                      Command="{Binding ToggleAutoStartCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Blacklist -->
            <Border Margin="0,0,0,12" CornerRadius="8"
                     Background="{DynamicResource SystemControlAcrylicElementBrush}"
                     BorderBrush="{DynamicResource SystemControlForegroundTransparentBrush}"
                     BorderThickness="1">
                <StackPanel Margin="20,16">
                    <TextBlock Text="Blacklist (excluded processes)"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Text="{Binding NewBlacklistItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="e.g. explorer.exe"
                                 Width="200" Margin="0,0,8,0"/>
                        <Button Content="Add" Command="{Binding AddBlacklistItemCommand}"
                                Width="60"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Blacklist}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" Height="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding}"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Width="28" Height="24"
                                            FontSize="12"
                                            Command="{Binding DataContext.RemoveBlacklistItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SystemButtonStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Whitelist -->
            <Border Margin="0,0,0,12" CornerRadius="8"
                     Background="{DynamicResource SystemControlAcrylicElementBrush}"
                     BorderBrush="{DynamicResource SystemControlForegroundTransparentBrush}"
                     BorderThickness="1">
                <StackPanel Margin="20,16">
                    <TextBlock Text="Whitelist (only track these)"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Leave empty to track all (excluding blacklist)."
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Text="{Binding NewWhitelistItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="e.g. chrome.exe"
                                 Width="200" Margin="0,0,8,0"/>
                        <Button Content="Add" Command="{Binding AddWhitelistItemCommand}"
                                Width="60"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Whitelist}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" Height="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding}"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Width="28" Height="24"
                                            FontSize="12"
                                            Command="{Binding DataContext.RemoveWhitelistItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SystemButtonStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Maintenance -->
            <Border Margin="0,0,0,12" CornerRadius="8"
                     Background="{DynamicResource SystemControlAcrylicElementBrush}"
                     BorderBrush="{DynamicResource SystemControlForegroundTransparentBrush}"
                     BorderThickness="1">
                <StackPanel Margin="20,16">
                    <TextBlock Text="Maintenance"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Prune old records now:"
                                   Width="200" VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <Button Content="Prune Now"
                                Command="{Binding PruneNowCommand}"
                                Width="120"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                       Margin="0,4,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
