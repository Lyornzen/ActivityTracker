<Page x:Class="ActivityTracker.UI.Views.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:vm="clr-namespace:ActivityTracker.UI.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:HistoryViewModel}"
      Title="History"
      Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <!-- Page title -->
            <TextBlock Text="Usage History"
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                       Margin="0,0,0,24"/>

            <!-- Period toggle -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="Period:"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           Margin="0,0,12,0"/>
                <RadioButton x:Name="Radio7Days"
                             Content="7 Days"
                             GroupName="Period"
                             IsChecked="True"
                             Margin="0,0,12,0"
                             FontSize="14"
                             Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                <RadioButton x:Name="Radio30Days"
                             Content="30 Days"
                             GroupName="Period"
                             FontSize="14"
                             Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            </StackPanel>

            <!-- KPI row -->
            <WrapPanel Orientation="Horizontal" Margin="0,0,0,16">

                <Border Width="240" Height="100" Margin="0,0,12,12" CornerRadius="8"
                         Background="{DynamicResource SystemControlAcrylicElementBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Total"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalRangeHours}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Width="240" Height="100" Margin="0,0,12,12" CornerRadius="8"
                         Background="{DynamicResource SystemControlAcrylicElementBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Daily Average"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DailyAverage}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

            <!-- Line chart -->
            <Border Margin="0,0,0,16" CornerRadius="8"
                     Background="{DynamicResource SystemControlAcrylicElementBrush}"
                     BorderBrush="{DynamicResource SystemControlForegroundTransparentBrush}"
                     BorderThickness="1">
                <StackPanel Margin="20,16">
                    <TextBlock Text="Daily Usage Trend"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               Margin="0,0,0,16"/>
                    <lvc:CartesianChart Series="{Binding ChartSeries}"
                                        XAxes="{Binding ChartXAxes}"
                                        YAxes="{Binding ChartYAxes}"
                                        Height="350"
                                        TooltipPosition="Top"
                                        ZoomMode="X"/>
                </StackPanel>
            </Border>

            <!-- Daily breakdown list -->
            <Border Margin="0,0,0,16" CornerRadius="8"
                     Background="{DynamicResource SystemControlAcrylicElementBrush}"
                     BorderBrush="{DynamicResource SystemControlForegroundTransparentBrush}"
                     BorderThickness="1">
                <StackPanel Margin="20,16">
                    <TextBlock Text="Daily Breakdown"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding DailySummaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3" Height="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Date, StringFormat={}{0:ddd, MMM dd}}"
                                               FontSize="14"
                                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <Binding Path="TotalSeconds"
                                                     Converter="{StaticResource SecondsToTimeConverter}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
