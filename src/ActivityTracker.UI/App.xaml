<Application x:Class="ActivityTracker.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:converters="clr-namespace:ActivityTracker.UI.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <converters:SecondsToTimeConverter x:Key="SecondsToTimeConverter" />
            <converters:BoolInverseConverter x:Key="BoolInverseConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
